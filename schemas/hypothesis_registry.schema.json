{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Tusgof/Yuehua-Lily/schemas/hypothesis_registry.schema.json",
  "title": "Lily hypothesis registry",
  "type": "object",
  "required": [
    "schema_version",
    "updated",
    "evidence_tiers",
    "family_stop_rule",
    "inference_policy",
    "hypotheses"
  ],
  "properties": {
    "schema_version": {"const": "lily_hypothesis_registry_v1"},
    "updated": {"type": "string", "format": "date"},
    "evidence_tiers": {
      "type": "object",
      "required": ["E0", "E1", "E2", "E3"],
      "additionalProperties": false,
      "properties": {
        "E0": {"type": "string", "minLength": 1},
        "E1": {"type": "string", "minLength": 1},
        "E2": {"type": "string", "minLength": 1},
        "E3": {"type": "string", "minLength": 1}
      }
    },
    "family_stop_rule": {"type": "object"},
    "inference_policy": {"type": "object"},
    "hypotheses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "family",
          "counts_toward_family_stop",
          "status",
          "statement",
          "economic_rationale",
          "testable_predictions",
          "validation_criteria",
          "falsification_criteria",
          "required_data",
          "mintrl_falsify",
          "mintrl_validate",
          "known_kill_zones",
          "dependencies",
          "evidence",
          "decision_log"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^L-[0-9]+$"},
          "family": {"type": "string", "minLength": 1},
          "counts_toward_family_stop": {"type": "boolean"},
          "status": {
            "enum": [
              "proposed",
              "active",
              "active_blocked",
              "scope_restricted",
              "falsified",
              "validated",
              "retired"
            ]
          },
          "statement": {"type": "string", "minLength": 1},
          "economic_rationale": {"type": "string", "minLength": 1},
          "testable_predictions": {"$ref": "#/$defs/non_empty_string_array"},
          "validation_criteria": {"$ref": "#/$defs/non_empty_string_array"},
          "falsification_criteria": {"$ref": "#/$defs/non_empty_string_array"},
          "required_data": {"$ref": "#/$defs/non_empty_string_array"},
          "mintrl_falsify": {"type": "object", "minProperties": 1},
          "mintrl_validate": {"type": "object", "minProperties": 1},
          "known_kill_zones": {"$ref": "#/$defs/non_empty_string_array"},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "evidence_tier"],
              "properties": {
                "path": {"type": "string", "minLength": 1},
                "evidence_tier": {"enum": ["E0", "E1", "E2", "E3"]}
              }
            }
          },
          "decision_log": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["date", "decision", "notes"],
              "properties": {
                "date": {"type": "string", "format": "date"},
                "decision": {"type": "string", "minLength": 1},
                "notes": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
