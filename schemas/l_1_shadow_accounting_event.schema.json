{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuehua.local/schemas/l_1_shadow_accounting_event.schema.json",
  "title": "Lily L-1 prospective shadow-accounting event record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "observation_id",
    "stream_id",
    "symbol",
    "event_type",
    "provider_or_broker_event_identifier_when_available",
    "effective_or_ex_date",
    "record_date_when_available",
    "payment_date_when_available",
    "cash_delta_usd",
    "unit_delta",
    "target_weight_tracking_delta",
    "hypothetical_rebalance_order_delta_usd",
    "source_observed_at",
    "source_container_sha256",
    "source_payload_sha256",
    "reference_nav_usd",
    "reference_quote_sha256",
    "first_seen_or_revision"
  ],
  "properties": {
    "observation_id": {"type": "string", "minLength": 1},
    "stream_id": {"enum": ["webull_th_test_ledger", "alpha_vantage_current_snapshot_shadow_ledger", "lily_yahoo_event_strategy_accounting"]},
    "symbol": {"enum": ["VTI", "VGK", "EWJ", "IPAC", "VWO", "IEF", "SCHP", "GLDM", "PDBC", "VNQI"]},
    "event_type": {"enum": ["cash_dividend", "capital_gains_distribution", "stock_split", "reverse_split"]},
    "provider_or_broker_event_identifier_when_available": {"type": ["string", "null"]},
    "effective_or_ex_date": {"type": "string", "format": "date"},
    "record_date_when_available": {"type": ["string", "null"], "format": "date"},
    "payment_date_when_available": {"type": ["string", "null"], "format": "date"},
    "cash_delta_usd": {"type": "number"},
    "unit_delta": {"type": "number"},
    "target_weight_tracking_delta": {"type": "number"},
    "hypothetical_rebalance_order_delta_usd": {"type": "number"},
    "source_observed_at": {"type": "string", "format": "date-time"},
    "source_container_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "reference_nav_usd": {"type": "number", "exclusiveMinimum": 0},
    "reference_quote_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "first_seen_or_revision": {"enum": ["first_seen", "revision"]}
  }
}
