{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Tusgof/Yuehua-Lily/schemas/provider_daily_bars.schema.json",
  "title": "Provider boundary: daily bars",
  "type": "object",
  "required": ["schema_version", "boundary_kind", "provider", "acquired_at", "fixture_only", "network_used", "paid_data_used", "records"],
  "properties": {
    "schema_version": {"const": "lily_provider_daily_bars_v1"},
    "boundary_kind": {"const": "daily_bars"},
    "provider": {"type": "string"},
    "acquired_at": {"type": "string", "format": "date-time"},
    "fixture_only": {"type": "boolean"},
    "network_used": {"type": "boolean"},
    "paid_data_used": {"type": "boolean"},
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["instrument_id", "session_date", "available_at", "open", "high", "low", "close", "adjusted_close", "volume", "currency", "adjustment_basis", "provider_revision", "is_backfilled"],
        "properties": {
          "instrument_id": {"type": "string"},
          "session_date": {"type": "string", "format": "date"},
          "available_at": {"type": "string", "format": "date-time"},
          "open": {"type": "number"},
          "high": {"type": "number"},
          "low": {"type": "number"},
          "close": {"type": "number"},
          "adjusted_close": {"type": "number"},
          "volume": {"type": "number", "minimum": 0},
          "currency": {"type": "string"},
          "adjustment_basis": {"enum": ["none", "split", "split_and_cash_distribution", "provider_total_return"]},
          "provider_revision": {"type": "string"},
          "is_backfilled": {"type": "boolean"}
        }
      }
    }
  }
}
