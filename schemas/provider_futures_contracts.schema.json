{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Tusgof/Yuehua-Lily/schemas/provider_futures_contracts.schema.json",
  "title": "Provider boundary: futures contracts",
  "type": "object",
  "required": ["schema_version", "boundary_kind", "provider", "acquired_at", "fixture_only", "network_used", "paid_data_used", "records"],
  "properties": {
    "schema_version": {"const": "lily_provider_futures_contracts_v1"},
    "boundary_kind": {"const": "futures_contracts"},
    "provider": {"type": "string"},
    "acquired_at": {"type": "string", "format": "date-time"},
    "fixture_only": {"type": "boolean"},
    "network_used": {"type": "boolean"},
    "paid_data_used": {"type": "boolean"},
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["contract_id", "root_symbol", "provider_symbol", "exchange", "currency", "contract_multiplier", "tick_size", "tick_value", "first_trade_date", "last_trade_date", "first_notice_date", "expiry_date", "delivery_type", "active", "provider_revision"],
        "properties": {
          "contract_id": {"type": "string"},
          "root_symbol": {"type": "string"},
          "provider_symbol": {"type": "string"},
          "exchange": {"type": "string"},
          "currency": {"type": "string"},
          "contract_multiplier": {"type": "number", "exclusiveMinimum": 0},
          "tick_size": {"type": "number", "exclusiveMinimum": 0},
          "tick_value": {"type": "number", "exclusiveMinimum": 0},
          "first_trade_date": {"type": "string", "format": "date"},
          "last_trade_date": {"type": "string", "format": "date"},
          "first_notice_date": {"type": ["string", "null"], "format": "date"},
          "expiry_date": {"type": "string", "format": "date"},
          "delivery_type": {"enum": ["cash", "physical"]},
          "active": {"type": "boolean"},
          "provider_revision": {"type": "string"}
        }
      }
    }
  }
}
