    "published_method_anchor": "Bailey/Lopez de Prado finite-sample Sharpe approximation as documented in the local source snapshot and independently reproduced in the Higanbana technical review.",
    "offline_reference": "SciPy 1.17.1 scipy.stats Normal CDF/PPF, skew(bias=True), and kurtosis(fisher=False,bias=True); used to generate anchors only, not required at runtime."
  },
  "conventions": {
    "sharpe": "mean divided by population standard deviation; unannualized",
    "skewness": "population standardized third central moment",
    "kurtosis": "raw Pearson population kurtosis, not excess kurtosis",
    "autocorrelation": "finite-sample Bartlett inflation for observed inference; asymptotic sum for prospective MinTRL planning",
    "newey_west": "Bartlett kernel with autocovariance divisor N",
    "independent_bets": "eigenvalue participation ratio multiplied by autocorrelation-adjusted time observations"
  },
